# Application settings
PROJECT_NAME="Ethara Seat Allocation & Project Mapping System"
API_V1_STR="/api/v1"

# Database config
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/ethara_seat_db"

# Security
# Run `openssl rand -hex 32` to generate a secure secret
JWT_SECRET="super-secret-jwt-key-change-in-production-12345"
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS Origins (comma-separated list)
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://ethara.vercel.app"

# AI LLM Provider Configuration
# Supported: "openai" (can be extended to others)
AI_PROVIDER="openai"
AI_MODEL="gpt-4o-mini"
AI_API_KEY="your-openai-api-key-here"
